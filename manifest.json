{
  "manifest_version": 3,
  "name": "X No-Scroll — keep your place",
  "version": "0.1.5",
  "description": "Keep your place when X (Twitter) loads new posts above you, plus an optional ✕ to dismiss the \"See new posts\" pill.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["src/bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
