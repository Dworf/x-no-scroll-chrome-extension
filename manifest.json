{
  "manifest_version": 3,
  "name": "X No-Scroll — keep your place",
  "version": "0.1.1",
  "description": "Keeps your scroll position fixed when X (Twitter) loads new posts above you (\"Show N posts\" / \"Show more posts\").",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    }
  ]
}
